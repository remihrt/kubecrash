{
  "name": "kubecrash",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "scripts/setup.sh",
  "mounts": [
    "source=${localWorkspaceFolder}/.kube,target=/home/vscode/.kube,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "runArgs": [
    "--network=host",
    "--hostname=kubecrash"
  ]
}
